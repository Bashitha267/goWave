# Java build output
/target/
*.class

# IDE and editor folders/files
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo

# Build tools output (generic)
dist/
build/
out/
debug/

# Test sources and outputs
test/
tests/
*_test.go

# Version control
.git/
.gitignore
.gitattributes
.svn/
.hg/

# Environment and secrets
.env*
*.env
*.pem
*.key
*.crt
config.local.*
*.local.yml

# Documentation and markdown
*.md
docs/
README*
HELP.md

# Temporary and local files
tmp/
temp/
*.tmp
.local/
local/

# Node.js, Python, Go (not detected, but safe to ignore common artifacts)
node_modules/
npm-debug.log
yarn-debug.log
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
/vendor/
*.test
.go-cache/

# Docker and Compose files (do NOT ignore Dockerfile itself)
docker-compose*

# Maven wrapper and gradle files should NOT be ignored (as per instructions)
# .mvnw
# .mvn/
# .gradlew
# .gradle/
